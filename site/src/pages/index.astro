---
import "../styles/global.css";
const canon = "canon 2.5.0-draft";
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Specline — the spec lives in the codebase</title>
    <meta name="description" content="Specline is a methodology for defining product work as specs that live in the codebase — structured so an AI agent knows what to build, what's out of scope, when it's done, and who decides." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Space+Grotesk:wght@400;500;600;700&family=Spectral:ital,wght@0,400;0,500;0,600;1,400&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      try {
        const t = localStorage.getItem("specline-theme");
        if (t === "paper" || t === "dark") document.documentElement.dataset.theme = t;
      } catch (e) {}
    </script>
    <style>
      /* The homepage has no TOC sidebar — undo the handbook layout's sidebar-era
         offsets and the two-column cover body. Page-scoped: only this page. */
      .cover { margin-left: 0; min-height: auto; padding: 76px 0 12px; align-items: start; }
      .book, .book-footer { margin-left: 0; }
      .cover-body { display: block; }
      .cover-lead { max-width: 60ch; }
      .cover-lead + .cover-lead { margin-top: 1.15rem; }
      .wrap { max-width: 1040px; }
      @media (min-width: 721px) { .doc-cards { grid-template-columns: repeat(3, 1fr); } }
    </style>
  </head>
  <body>
    <header class="topbar">
      <span class="glyph" aria-hidden="true"></span>
      <span class="wordmark">Specline</span>
      <span class="canon">{canon}</span>
      <span class="tb-spacer"></span>
      <a class="tb-btn" href="/handbook/the-problem">Handbook</a>
      <a class="tb-btn" href="/docs/reference">Reference</a>
      <a class="tb-btn" href="/docs">Docs</a>
      <a class="tb-btn" href="/spec.md">For agents ↗</a>
      <button class="tb-btn" id="themeBtn" aria-label="Toggle theme">◐ theme</button>
    </header>

    <section class="cover">
      <div class="cover-inner">
        <div class="cover-top">Specline · {canon}</div>
        <h1>Specs your agents<br />can build from.</h1>
        <div class="cover-body">
          <p class="cover-lead">
            Specline is a methodology for defining product work as <strong>specs that live in
            your codebase</strong> — every feature in one consistent shape, so an AI agent
            knows exactly what to build, what's out of scope, when it's done, and who decides.
          </p>
          <p class="cover-lead">
            It exists because the usual way fails. Hand an agent a feature and it builds what
            you said, then confidently invents the parts you didn't — and you find out at
            review. A plan in a task tracker, apart from the code, can't constrain that.
            Specline moves the spec into the repo, where it can.
          </p>
          <div class="btn-row">
            <a class="btn-primary" href="/handbook/the-problem">Start with the problem →</a>
            <a class="tb-btn" href="/spec.md">For your agents ↗</a>
          </div>
        </div>
      </div>
    </section>

    <main class="book">
      <div class="wrap">
        <h2 style="margin-bottom:0.5rem">Three ways in</h2>
        <p class="lead" style="margin-bottom:1.5rem">Learn it, look it up, or run it.</p>
        <div class="doc-cards">
          <a class="doc-card" href="/handbook/the-problem">
            <div class="dc-t">Learn it — the handbook →</div>
            <div class="dc-d">The argument, start to finish: the problem, the bet, and how the methodology works. Read this first.</div>
          </a>
          <a class="doc-card" href="/docs/reference">
            <div class="dc-t">Look it up — reference →</div>
            <div class="dc-d">The operational detail: folders, frontmatter fields, <code>specline.yml</code>, the lifecycle, the boundaries.</div>
          </a>
          <a class="doc-card" href="/docs/setup">
            <div class="dc-t">Run it — get started →</div>
            <div class="dc-d">Install the tooling and point an agent at your repo: shape a spec, check it, build from it.</div>
          </a>
        </div>
        <p class="doc-note" style="margin-top:1.5rem">
          Also: <a href="/spec.md">the canon</a> (the full methodology as raw markdown, for agents) ·
          <a href="/honest-pitch">the honest pitch</a> (every claim, with how it breaks) ·
          <a href="/docs/why">why now</a> (why this helps more as models get stronger).
        </p>
      </div>
    </main>

    <footer class="book-footer">
      <span>Specline · {canon} · this site re-reviews when the canon amends</span>
      <span><a href="/spec.md">/spec.md</a> · <a href="/llms.txt">/llms.txt</a> · "Specline" is a working name</span>
    </footer>

    <script>
      const root = document.documentElement;
      document.getElementById("themeBtn")?.addEventListener("click", () => {
        const next = root.dataset.theme === "paper" ? "dark" : "paper";
        root.dataset.theme = next;
        try { localStorage.setItem("specline-theme", next); } catch (e) {}
      });
    </script>
  </body>
</html>
