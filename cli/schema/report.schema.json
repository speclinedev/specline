{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://specline.dev/schema/doctor-report.json",
  "title": "doctor report",
  "type": "object",
  "required": ["tool_version", "canon", "mode", "tier", "summary", "findings"],
  "properties": {
    "tool_version": { "type": "string" },
    "canon": { "type": "string" },
    "mode": { "type": "string", "enum": ["gate", "author"] },
    "tier": { "type": "integer" },
    "summary": {
      "type": "object",
      "required": ["errors", "warnings", "info"],
      "properties": {
        "errors": { "type": "integer" },
        "warnings": { "type": "integer" },
        "info": { "type": "integer" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "severity", "scope", "file", "line", "message", "fix_hint"],
        "properties": {
          "rule_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["error", "warning", "info"] },
          "scope": { "type": "string", "enum": ["repo", "spec"] },
          "file": { "type": ["string", "null"] },
          "line": { "type": ["integer", "null"] },
          "message": { "type": "string" },
          "fix_hint": { "type": "string" },
          "label": { "type": "string" }
        }
      }
    }
  }
}
